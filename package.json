{
  "name": "oasis-firebase-api",
  "version": "1.0.0",
  "description": "Oasis API endpoints using Firebase and Gemini",
  "main": "server.js",
  "scripts": {
    "start": "node api/index.js",
    "build": "npm --prefix client install && npm --prefix client run build",
    "dev:server": "node api/index.js",
    "dev:client": "npm --prefix client run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
